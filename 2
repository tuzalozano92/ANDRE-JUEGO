<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Soapayuca Academy V13</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;700&family=Nunito:wght@400;900&display=swap');
        body { margin: 0; overflow: hidden; background: #1a1a1a; color: #4af626; font-family: 'Nunito', sans-serif; }
        .canvas { height: 60vh; position: relative; overflow: hidden; background: #222; border-bottom: 4px solid #444; }
        .terminal { height: 40vh; background: #000; padding: 20px; font-family: 'Fira Code', monospace; overflow-y: auto; }
        .car-img { position: absolute; width: 300px; border-radius: 20px; border: 5px solid white; animation: move 2.5s linear forwards; }
        @keyframes move { from { left: -500px; } to { left: 110%; } }
        .guide-char { position: absolute; font-size: 20vw; opacity: 0.1; color: white; font-weight: 900; }
    </style>
</head>
<body>
    <div id="login" class="fixed inset-0 bg-black z-50 flex flex-col items-center justify-center">
        <h1 class="text-4xl font-black text-white mb-8">SOAPAYUCA ADVENTURE</h1>
        <button onclick="start()" class="bg-orange-500 text-white px-10 py-5 rounded-3xl font-black text-2xl">INICIAR SESION</button>
    </div>

    <div class="canvas" id="canvas">
        <div id="guide" class="guide-char inset-0 flex items-center justify-center"></div>
        <div id="visual-area" class="h-full flex items-center justify-center text-9xl">🤠</div>
    </div>

    <div class="terminal" id="term">
        <div class="text-yellow-400 font-bold mb-2" id="mission">CARGANDO...</div>
        <div id="output"></div>
    </div>

    <script>
        let xp = 0, currentWord = "ANDRE", charIdx = 0;
        const log = (m) => { const d = document.getElementById('output'); d.innerHTML = `> ${m}<br>${d.innerHTML}`; };
        function hablar(m) { window.speechSynthesis.cancel(); const u = new SpeechSynthesisUtterance(m); u.lang='es-MX'; window.speechSynthesis.speak(u); }

        function start() {
            document.getElementById('login').style.display = 'none';
            hablar("Empecemos a programar ingeniero André, bienvenido a Soapayuca.");
            newMission();
        }

        function newMission() {
            const list = ["ANDRE", "CABALLO", "HONGO", "JETTA", "123", "456"];
            currentWord = list[Math.floor(Math.random()*list.length)];
            charIdx = 0;
            document.getElementById('mission').innerText = `MISION: ESCRIBE "${currentWord}"`;
            document.getElementById('guide').innerText = currentWord[0];
            hablar("Escribe " + currentWord);
        }

        window.addEventListener('keydown', (e) => {
            const k = e.key.toUpperCase();
            
            // Lógica de aprendizaje
            if(k === currentWord[charIdx]) {
                charIdx++;
                hablar(k);
                if(charIdx >= currentWord.length) {
                    hablar("¡Excelente Ingeniero!");
                    xp += 10;
                    newMission();
                } else {
                    document.getElementById('guide').innerText = currentWord[charIdx];
                }
            }

            // Atajos de coches y aventuras
            if(k === 'R') { 
                hablar("la R de Ricardo el Jetta negro");
                showImg('jetta.jpg', '🚗');
            }
            if(k === 'K') { hablar("K de Kike Buick dorada"); showImg('buick.jpg', '🚙'); }
            if(k === 'D') { hablar("Rescatando dinosaurio de la cascada"); document.getElementById('visual-area').innerText = "🦕💦"; }
            if(k === 'S') { hablar("Preparando sopa de pollo y verduras"); document.getElementById('visual-area').innerText = "🥣"; }
        });

        function showImg(src, emo) {
            const img = document.createElement('div');
            img.className = 'car-img';
            img.style.top = '20%';
            img.innerHTML = `<img src="${src}" style="width:100%" onerror="this.outerHTML='<span style=\'font-size:100px\'>${emo}</span>'">`;
            document.getElementById('canvas').appendChild(img);
            setTimeout(() => img.remove(), 2600);
        }
    </script>
</body>
</html>
